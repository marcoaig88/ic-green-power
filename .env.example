# Database Supabase (Settings → Database → Connection string → URI)
# Usa la connection string "Transaction" o "Session" con password del DB.
# Esempio: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Per migrate Prisma preferisci la Direct connection (porta 5432):
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Supabase API (Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_STORAGE_BUCKET="receipts"

# Gemini
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"

# Session cookie (usa una stringa lunga e casuale in produzione)
SESSION_SECRET="change-me-to-a-long-random-string"
