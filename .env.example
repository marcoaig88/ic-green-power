# Runtime (Vercel): Transaction pooler — porta 6543
# Formato: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# CLI / migrate / db push: Direct connection — porta 5432
DIRECT_URL="postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres"

NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_STORAGE_BUCKET="receipts"

GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"
SESSION_SECRET="change-me-to-a-long-random-string"
